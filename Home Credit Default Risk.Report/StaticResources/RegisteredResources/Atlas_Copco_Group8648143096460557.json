{
  "name": "Atlas Copco Group",
  "dataColors": [
    "#054E5A",
    "#A1A9B4",
    "#E1B77E",
    "#5D7875",
    "#9E1F63",
    "#123F6D",
    "#C03627",
    "#4C9F70"
  ],
  "background": "#FFFFFF",
  "foreground": "#000000",
  "tableAccent": "#0099CC",
  "textClasses": {
    "label": {
      "color": "#000000",
      "fontFace": "'Segoe UI', wf_segoe-ui_normal, helvetica, arial, sans-serif",
      "fontSize": 12
    },
    "callout": {
      "color": "#054E5A",
      "fontFace": "'Segoe UI', wf_segoe-ui_normal, helvetica, arial, sans-serif",
      "fontSize": 20
    },
    "title": {
      "color": "#000000",
      "fontFace": "'Segoe UI', wf_segoe-ui_normal, helvetica, arial, sans-serif",
      "fontSize": 14
    },
    "header": {
      "color": "#000000",
      "fontFace": "'Segoe UI', wf_segoe-ui_normal, helvetica, arial, sans-serif",
      "fontSize": 14
    }
  },
  "bad": "#C03627",
  "neutral": "#E1B77E",
  "good": "#4C9F70",
  "minimum": "#A1A9B4",
  "center": "#CED9D7",
  "maximum": "#5D7875",
  "visualStyles": {
    "*": {
      "*": {
        "visualTooltip": [
          {
            "titleFontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "valueFontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "background": {
              "solid": {
                "color": "#373D41"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "titleSize": 10,
            "headerSize": 10,
            "checkboxAndApplyColor": {
              "solid": {
                "color": "#117865"
              }
            }
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "backgroundColor": {
              "solid": {
                "color": "#F6F6F6"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "textSize": 10,
            "transparency": 0
          },
          {
            "$id": "Available",
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "textSize": 10
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#F5F5F6"
              }
            },
            "show": true,
            "radius": 10
          }
        ],
        "visualHeader": [
          {
            "border": {
              "solid": {
                "color": "#E6E6E6"
              }
            }
          }
        ],
        "visualHeaderTooltip": [
          {
            "background": {
              "solid": {
                "color": "#373D41"
              }
            },
            "titleFontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#E6E6E6"
              }
            }
          }
        ]
      }
    }
  }
}