model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: nl-BE
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

/// In this Grouping, we will store all Calendar creation queries
/// 
queryGroup CALENDAR

	annotation PBI_QueryGroupOrder = 3

queryGroup 'CALENDAR\PARAMETERS CALENDAR'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'MEASURE TABLES'

	annotation PBI_QueryGroupOrder = 4

queryGroup 'PARAMETERS DATASOURCES'

	annotation PBI_QueryGroupOrder = 5

queryGroup DIMENSIONS

	annotation PBI_QueryGroupOrder = 0

queryGroup FACTS

	annotation PBI_QueryGroupOrder = 1

queryGroup 'DATA ISLANDS'

	annotation PBI_QueryGroupOrder = 6

queryGroup 'DATA ISLANDS\PARAMETERS DATA ISLANDS'

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Measures Technical","Measures Design","Environment","Parameter_Environment","_StartDate","_EndDate","Date","_Language","Refresh Dates","factBureauCredits","factApplications","factBureauMonthlyStatus","factPreviousApplications","dimApplicant","dimCreditType","dimBureauStatus","dimRelativeMonth"]

annotation PBI_ProTooling = ["DevMode"]

ref table 'Measures Technical'
ref table Environment
ref table 'Measures Design'
ref table Date
ref table 'Refresh Dates'
ref table Par_AutoPeriod
ref table factApplications
ref table factBureauCredits
ref table factBureauMonthlyStatus
ref table factPreviousApplications
ref table dimApplicant
ref table dimCreditType
ref table dimBureauStatus
ref table dimRelativeMonth

ref cultureInfo en-US

